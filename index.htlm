                <div class="color-dot" style="background: #ff5c5c;" onclick="changeTextColor(1, '#ff5c5c', this)"></div>
                <div class="color-dot" style="background: #f59e0b;" onclick="changeTextColor(1, '#f59e0b', this)"></div>
            </div>
            <div class="btn-group">
                <button class="minus" onclick="changeScore(1, -1)">−</button>
                <button class="plus" onclick="changeScore(1, 1)">+</button>
            </div>
        </div>

        <!-- NGƯỜI CHƠI 2 -->
        <div class="player-box" id="p2-box">
            <input type="text" class="player-name" value="Cơ thủ 2" />
            <div class="score-zone">
                <div id="score2" class="playerScore">0</div>
            </div>
            <!-- Đổi màu chữ P2 -->
            <div class="color-bar">
                <div class="color-dot active" style="background: #ffffff;" onclick="changeTextColor(2, '#ffffff', this)"></div>
                <div class="color-dot" style="background: #4ade80;" onclick="changeTextColor(2, '#4ade80', this)"></div>
                <div class="color-dot" style="background: #ff5c5c;" onclick="changeTextColor(2, '#ff5c5c', this)"></div>
                <div class="color-dot" style="background: #f59e0b;" onclick="changeTextColor(2, '#f59e0b', this)"></div>
            </div>
            <div class="btn-group">
                <button class="minus" onclick="changeScore(2, -1)">−</button>
                <button class="plus" onclick="changeScore(2, 1)">+</button>
            </div>
        </div>
    </div>

    <!-- TỔNG ĐIỂM CẢ 2 BÊN -->
    <div class="bottomBar">
        <span>Tổng điểm trận đấu</span>
        <div id="totalPoint">0</div>
    </div>

    <!-- ĐỔI MÀU NỀN -->
    <div class="themeSection">
        <label>Màu bàn bida</label>
        <div class="themeBox">
            <button style="background: #1e4d2b;" onclick="changeBgTheme('theme1')"></button>
            <button style="background: #263b70;" onclick="changeBgTheme('theme2')"></button>
            <button style="background: #70264f;" onclick="changeBgTheme('theme3')"></button>
            <button style="background: #4b5563;" onclick="changeBgTheme('theme4')"></button>
        </div>
    </div>

    <!-- TIỆN ÍCH HỖ TRỢ -->
    <div class="bottomButton">
        <button onclick="resetScore()">↻ Reset trận đấu</button>
        <button onclick="undo()">↩ Hoàn tác</button>
    </div>
</div>

<script>
    // Khởi tạo trạng thái cho cả 2 người chơi
    let player1 = { score: 0 };
    let player2 = { score: 0 };
    let history = []; // Lưu lịch sử trận đấu

    const bgThemes = {
        theme1: 'radial-gradient(circle at top, #1e4d2b, #05140b 55%)',
        theme2: 'radial-gradient(circle at top, #263b70, #080810 55%)',
        theme3: 'radial-gradient(circle at top, #70264f, #10080e 55%)',
        theme4: 'radial-gradient(circle at top, #4b5563, #111827 55%)'
    };

    /**
     * Thay đổi điểm số cho người chơi cụ thể
     * @param {number} playerNum - Cơ thủ số 1 hoặc 2
     * @param {number} value - Giá trị cộng/trừ (1 hoặc -1)
     */
    function changeScore(playerNum, value) {
        // Lưu lịch sử trước khi đổi điểm
        history.push({
            p1: { ...player1 },
            p2: { ...player2 }
        });

        if (playerNum === 1) {
            player1.score += value;
        } else {
            player2.score += value;
        }

        updateUI();
        triggerPopAnimation(playerNum);
    }

    /**
     * Đồng bộ điểm số lên giao diện
     */
    function updateUI() {
        document.getElementById("score1").textContent = player1.score;
        document.getElementById("score2").textContent = player2.score;

        // Tính tổng điểm cả trận (Tổng điểm của cả người 1 và người 2)
        let total = player1.score + player2.score;
        document.getElementById("totalPoint").textContent = total;
    }

    /**
     * Đổi màu chữ cho điểm số từng người
     */
    function changeTextColor(playerNum, colorHex, dotElement) {
        document.getElementById(`score${playerNum}`).style.color = colorHex;

        // Reset viền trắng của các nút màu cùng nhóm bên đó
        const dots = dotElement.parentElement.querySelectorAll('.color-dot');
        dots.forEach(dot => dot.classList.remove('active'));
        dotElement.classList.add('active');
    }

    /**
     * Thay đổi màu nền bàn bida
     */
    function changeBgTheme(themeKey) {
        if (bgThemes[themeKey]) {
            document.body.style.background = bgThemes[themeKey];
        }
    }

    /**
     * Hoàn tác hành động vừa thực hiện (Undo)
     */
    function undo() {
        if (history.length > 0) {
            const previousState = history.pop();
            player1 = previousState.p1;
            player2 = previousState.p2;
            updateUI();
        }
    }

    /**
     * Xóa điểm lập trận mới kèm theo logic cảnh báo
     */
    function resetScore() {
        let total = player1.score + player2.score;

        // LOGIC CẢNH BÁO: Nếu tổng điểm khác 0 (tức là trận đấu đang có điểm số)
        if (total !== 0) {
            let confirmReset = confirm("Trận đấu đang có điểm! Bạn có chắc chắn muốn Reset toàn bộ về 0 không?");
            if (!confirmReset) {
                return; // Người dùng chọn Hủy -> Dừng hàm không xóa điểm nữa
            }
        }

        // Lưu lịch sử để phòng trường hợp bấm nhầm đồng ý vẫn Undo được
        history.push({
            p1: { ...player1 },
            p2: { ...player2 }
        });

        player1.score = 0;
        player2.score = 0;
        updateUI();
    }

    /**
     * Hiệu ứng nảy số và rung máy
     */
    function triggerPopAnimation(playerNum) {
        if (navigator.vibrate) {
            navigator.vibrate(30); 
        }

        const scoreElement = document.getElementById(`score${playerNum}`);
        if (scoreElement) {
            scoreElement.classList.remove("pop");
            void scoreElement.offsetWidth; 
            scoreElement.classList.add("pop");
        }
    }

    document.addEventListener("DOMContentLoaded", updateUI);
</script>

</body>
</html>
