<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bida Score - 2 Players</title>
    
    <!-- FONT OUTFIT -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800;900&display=swap" rel="stylesheet">

    <style>
        /* ==========================================================================
           RESET & BASE STYLES
           ========================================================================== */
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            background: radial-gradient(circle at top, #1e4d2b, #05140b 55%); /* Mặc định xanh lá bida */
            color: white;
            font-family: 'Outfit', sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            transition: background 0.4s ease;
        }

        /* ==========================================================================
           MAIN CONTAINER (RỘNG HƠN ĐỂ CHỨA 2 NGƯỜI)
           ========================================================================== */
        .card {
            width: min(95vw, 650px);
            padding: 30px 20px;
            border-radius: 30px;
            background: rgba(255, 255, 255, .08);
            backdrop-filter: blur(25px);
            -webkit-backdrop-filter: blur(25px);
            border: 1px solid rgba(255, 255, 255, .12);
            box-shadow: 0 25px 60px rgba(0, 0, 0, .5);
        }

        h1 {
            text-align: center;
            margin: 0 0 25px 0;
            font-size: 26px;
            font-weight: 900;
            letter-spacing: 0.5px;
        }

        /* LAYOUT CHIA ĐÔI CHO 2 NGƯỜI CHƠI */
        .players-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            position: relative;
        }

        /* Vạch ngăn cách dọc ở giữa 2 người chơi */
        .players-grid::after {
            content: '';
            position: absolute;
            top: 10%;
            bottom: 10%;
            left: 50%;
            width: 1px;
            background: rgba(255, 255, 255, 0.15);
            transform: translateX(-50%);
        }

        .player-box {
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;
        }

        /* KHU VỰC NHẬP TÊN */
        .player-name {
            font-size: 20px;
            font-weight: 800;
            text-align: center;
            background: transparent;
            border: none;
            color: white;
            font-family: 'Outfit', sans-serif;
            width: 80%;
            border-bottom: 2px dashed rgba(255, 255, 255, 0.2);
            padding: 2px 5px;
            cursor: pointer;
        }

        .player-name:focus {
            outline: none;
            border-bottom-color: #2563eb;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 6px;
        }

        /* ==========================================================================
           SCORE & INDIVIDUAL COLOR PICKER
           ========================================================================== */
        .score-zone {
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            width: 100%;
            margin: 10px 0;
        }

        .playerScore {
            font-size: clamp(70px, 15vw, 100px);
            font-weight: 900;
            line-height: 1;
            letter-spacing: -3px;
            color: white;
            transition: transform 0.1s ease;
        }

        .playerScore.pop {
            animation: pop .18s ease;
        }

        @keyframes pop {
            50% { transform: scale(1.15); }
        }

        /* Thanh đổi màu chữ nằm ngang dưới mỗi bên điểm */
        .color-bar {
            display: flex;
            gap: 6px;
            margin-bottom: 15px;
            background: rgba(0,0,0,0.2);
            padding: 5px 10px;
            border-radius: 20px;
        }

        .color-dot {
            width: 16px;
            height: 16px;
            border-radius: 50%;
            cursor: pointer;
            border: 2px solid transparent;
        }

        .color-dot.active {
            border-color: white;
        }

        /* BUTTONS TĂNG GIẢM */
        .btn-group {
            display: flex;
            gap: 10px;
            width: 90%;
        }

        .btn-group button {
            flex: 1;
            height: 55px;
            border: 0;
            border-radius: 16px;
            color: white;
            font-size: 26px;
            font-weight: 900;
            cursor: pointer;
            transition: transform 0.1s ease;
            box-shadow: inset 0 0 15px rgba(255, 255, 255, .15);
        }

        .btn-group button:active { transform: scale(.92); }
        .minus { background: linear-gradient(135deg, #ff4d4d, #b91c1c); }
        .plus { background: linear-gradient(135deg, #22c55e, #15803d); }

        /* ==========================================================================
           BOTTOM STATS & ACTIONS
           ========================================================================== */
        .bottomBar {
            margin-top: 25px;
            padding: 15px 20px;
            border-radius: 20px;
            background: rgba(255, 255, 255, .05);
            display: flex;
            justify-content: space-between;
            align-items: center;
            border: 1px solid rgba(255, 255, 255, .05);
        }

        .bottomBar span {
            font-size: 13px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            opacity: .6;
        }

        #totalPoint {
            font-size: 32px;
            font-weight: 900;
            color: #f59e0b;
        }

        .themeSection {
            margin-top: 20px;
            text-align: center;
        }

        .themeSection label {
            font-size: 11px;
            opacity: 0.5;
            text-transform: uppercase;
            letter-spacing: 1px;
            display: block;
            margin-bottom: 8px;
        }

        .themeBox {
            display: flex;
            justify-content: center;
            gap: 12px;
        }

        .themeBox button {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            border: 2px solid rgba(255, 255, 255, 0.4);
            cursor: pointer;
        }

        .bottomButton {
            display: flex;
            gap: 12px;
            margin-top: 20px;
        }

        .bottomButton button {
            flex: 1;
            height: 55px;
            border: 0;
            border-radius: 18px;
            background: #2563eb;
            color: white;
            font-size: 16px;
            font-weight: 800;
            cursor: pointer;
            transition: background 0.2s, transform 0.1s;
        }

        .bottomButton button:hover { background: #1d4ed8; }
        .bottomButton button:active { transform: scale(.95); }

        /* RESPONSIVE FOR MOBILE */
        @media(max-width: 500px) {
            .players-grid { grid-template-columns: 1fr; gap: 35px; }
            .players-grid::after { display: none; }
            .playerScore { font-size: 90px; }
        }
    </style>
</head>
<body>

<div class="card">
    <h1>🎱 BIDA SCORE BOARD</h1>

    <div class="players-grid">
        <!-- NGƯỜI CHƠI 1 -->
        <div class="player-box" id="p1-box">
            <input type="text" class="player-name" value="Cơ thủ 1" />
            <div class="score-zone">
                <div id="score1" class="playerScore">0</div>
            </div>
            <!-- Đổi màu chữ P1 -->
            <div class="color-bar">
                <div class="color-dot active" style="background: #ffffff;" onclick="changeTextColor(1, '#ffffff', this)"></div>
                <div class="color-dot" style="background: #4ade80;" onclick="changeTextColor(1, '#4ade80', this)"></div>
                <div class="color-dot" style="background: #ff5c5c;" onclick="changeTextColor(1, '#ff5c5c', this)"></div>
                <div class="color-dot" style="background: #f59e0b;" onclick="changeTextColor(1, '#f59e0b', this)"></div>
            </div>
            <div class="btn-group">
                <button class="minus" onclick="changeScore(1, -1)">−</button>
                <button class="plus" onclick="changeScore(1, 1)">+</button>
            </div>
        </div>

        <!-- NGƯỜI CHƠI 2 -->
        <div class="player-box" id="p2-box">
            <input type="text" class="player-name" value="Cơ thủ 2" />
            <div class="score-zone">
                <div id="score2" class="playerScore">0</div>
            </div>
            <!-- Đổi màu chữ P2 -->
            <div class="color-bar">
                <div class="color-dot active" style="background: #ffffff;" onclick="changeTextColor(2, '#ffffff', this)"></div>
                <div class="color-dot" style="background: #4ade80;" onclick="changeTextColor(2, '#4ade80', this)"></div>
                <div class="color-dot" style="background: #ff5c5c;" onclick="changeTextColor(2, '#ff5c5c', this)"></div>
                <div class="color-dot" style="background: #f59e0b;" onclick="changeTextColor(2, '#f59e0b', this)"></div>
            </div>
            <div class="btn-group">
                <button class="minus" onclick="changeScore(2, -1)">−</button>
                <button class="plus" onclick="changeScore(2, 1)">+</button>
            </div>
        </div>
    </div>

    <!-- TỔNG ĐIỂM CẢ 2 BÊN -->
    <div class="bottomBar">
        <span>Tổng điểm trận đấu</span>
        <div id="totalPoint">0</div>
    </div>

    <!-- ĐỔI MÀU NỀN -->
    <div class="themeSection">
        <label>Màu bàn bida</label>
        <div class="themeBox">
            <button style="background: #1e4d2b;" onclick="changeBgTheme('theme1')"></button>
            <button style="background: #263b70;" onclick="changeBgTheme('theme2')"></button>
            <button style="background: #70264f;" onclick="changeBgTheme('theme3')"></button>
            <button style="background: #4b5563;" onclick="changeBgTheme('theme4')"></button>
        </div>
    </div>

    <!-- TIỆN ÍCH HỖ TRỢ -->
    <div class="bottomButton">
        <button onclick="resetScore()">↻ Reset trận đấu</button>
        <button onclick="undo()">↩ Hoàn tác</button>
    </div>
</div>

<script>
    // Khởi tạo trạng thái cho cả 2 người chơi
    let player1 = { score: 0 };
    let player2 = { score: 0 };
    let history = []; // Lưu lịch sử trận đấu

    const bgThemes = {
        theme1: 'radial-gradient(circle at top, #1e4d2b, #05140b 55%)',
        theme2: 'radial-gradient(circle at top, #263b70, #080810 55%)',
        theme3: 'radial-gradient(circle at top, #70264f, #10080e 55%)',
        theme4: 'radial-gradient(circle at top, #4b5563, #111827 55%)'
    };

    /**
     * Thay đổi điểm số cho người chơi cụ thể
     * @param {number} playerNum - Cơ thủ số 1 hoặc 2
     * @param {number} value - Giá trị cộng/trừ (1 hoặc -1)
     */
    function changeScore(playerNum, value) {
        // Lưu lịch sử trước khi đổi điểm
        history.push({
            p1: { ...player1 },
            p2: { ...player2 }
        });

        if (playerNum === 1) {
            player1.score += value;
        } else {
            player2.score += value;
        }

        updateUI();
        triggerPopAnimation(playerNum);
    }

    /**
     * Đồng bộ điểm số lên giao diện
     */
    function updateUI() {
        document.getElementById("score1").textContent = player1.score;
        document.getElementById("score2").textContent = player2.score;

        // Tính tổng điểm cả trận (Tổng điểm của cả người 1 và người 2)
        let total = player1.score + player2.score;
        document.getElementById("totalPoint").textContent = total;
    }

    /**
     * Đổi màu chữ cho điểm số từng người
     */
    function changeTextColor(playerNum, colorHex, dotElement) {
        document.getElementById(`score${playerNum}`).style.color = colorHex;

        // Reset viền trắng của các nút màu cùng nhóm bên đó
        const dots = dotElement.parentElement.querySelectorAll('.color-dot');
        dots.forEach(dot => dot.classList.remove('active'));
        dotElement.classList.add('active');
    }

    /**
     * Thay đổi màu nền bàn bida
     */
    function changeBgTheme(themeKey) {
        if (bgThemes[themeKey]) {
            document.body.style.background = bgThemes[themeKey];
        }
    }

    /**
     * Hoàn tác hành động vừa thực hiện (Undo)
     */
    function undo() {
        if (history.length > 0) {
            const previousState = history.pop();
            player1 = previousState.p1;
            player2 = previousState.p2;
            updateUI();
        }
    }

    /**
     * Xóa điểm lập trận mới kèm theo logic cảnh báo
     */
    function resetScore() {
        let total = player1.score + player2.score;

        // LOGIC CẢNH BÁO: Nếu tổng điểm khác 0 (tức là trận đấu đang có điểm số)
        if (total !== 0) {
            let confirmReset = confirm("Trận đấu đang có điểm! Bạn có chắc chắn muốn Reset toàn bộ về 0 không?");
            if (!confirmReset) {
                return; // Người dùng chọn Hủy -> Dừng hàm không xóa điểm nữa
            }
        }

        // Lưu lịch sử để phòng trường hợp bấm nhầm đồng ý vẫn Undo được
        history.push({
            p1: { ...player1 },
            p2: { ...player2 }
        });

        player1.score = 0;
        player2.score = 0;
        updateUI();
    }

    /**
     * Hiệu ứng nảy số và rung máy
     */
    function triggerPopAnimation(playerNum) {
        if (navigator.vibrate) {
            navigator.vibrate(30); 
        }

        const scoreElement = document.getElementById(`score${playerNum}`);
        if (scoreElement) {
            scoreElement.classList.remove("pop");
            void scoreElement.offsetWidth; 
            scoreElement.classList.add("pop");
        }
    }

    document.addEventListener("DOMContentLoaded", updateUI);
</script>

</body>
</html><!DOCTYPE html>
